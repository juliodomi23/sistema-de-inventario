# Generar con: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=

# Nombre de la base de datos en MongoDB
DB_NAME=inventario

# Credenciales del administrador (se crean automáticamente al iniciar)
ADMIN_EMAIL=admin@tuempresa.com
ADMIN_PASSWORD=

# Credenciales del vendedor (se crean automáticamente al iniciar)
VENDEDOR_EMAIL=vendedor@tuempresa.com
VENDEDOR_PASSWORD=

# URL del frontend (para CORS) — en EasyPanel es la URL pública del servicio frontend
# Puede ser múltiples separadas por coma: https://app.com,https://www.app.com
ALLOWED_ORIGINS=https://tu-dominio.com
